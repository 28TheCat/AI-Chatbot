// 省略...

// 导入Pinia store
import { useChatStore } from '@/stores/chatStore'

// 获取 chat store
const chatStore = useChatStore()

// 省略...

onMounted(() => {
  const firstMessage = history.state?.firstMessage
  // 检查跳转路由时，是否有初始消息
  if (firstMessage) {
    message.value = firstMessage
    // 发送消息
    sendMessage({
      selectedModel: chatStore.selectedModel,
      isNetworkSearch: chatStore.isNetworkSearchSelected
    })
  }
})

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_block, lang=, fileSize=11942}, score=null}, Document{id='0a4ab5ce-0818-4b9d-80d6-a83d396b9666', text='请求体构建完毕后，接下来，准备使用 fetch-event-source 库调用后端 SSE 接口，实现流式对话功能，最终效果如下：编辑 ChatPage.vue 聊天对话页，继续补充 sendMessage() 发送消息事件方法中的处理逻辑，代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_inline, title=调用 SSE 接口, fileSize=11942}, score=null}, Document{id='35d90918-9c7b-4cf9-af0d-558f74b50dd0', text='<script setup>
// 省略..
import { fetchEventSource } from '@microsoft/fetch-event-source'

// 省略...

// 发送消息
const sendMessage = async (payload) => {
  // 省略...

  // 点击发送按钮后，清空输入框
  message.value = ''

  // 添加一个占位的回复消息
  chatList.value.push({ role: 'assistant', content: ''})

  try {
    // 构建请求体
    const requestBody = {
      message: userMessage,
      chatId: chatId.value,
      modelName: payload.selectedModel?.name,
      networkSearch: payload.isNetworkSearch
    }

    // 响应的回答
    let responseText = ''
    // 获取最后一条消息
    const lastMessage = chatList.value[chatList.value.length - 1]

    const controller = new AbortController()
    const signal = controller.signal

	// 调用 SSE 流式对话接口
    fetchEventSource('http://localhost:8080/chat/completion', {
      method: 'POST',
      signal: signal,
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(requestBody),
      onmessage(msg) {
        if (msg.event === '') {
          // 解析 JSON
          let parseJson = JSON.parse(msg.data)
          // 持续追加流式回答
          responseText += parseJson.v

          // 更新最后一条消息
          chatList.value[chatList.value.length - 1].content = responseText
          // 滚动到底部
          scrollToBottom()
        }
        else if (msg.event === 'close') {
          console.log('-- sse close')
          controller.abort();
        }
      },
      onerror(err) {
        throw err;    // 必须 throw 才能停止 
      }
    })


  } catch (error) {
    // 省略...
  }

}

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_block, lang=, fileSize=11942}, score=null}, Document{id='5a7a85aa-27a4-4ca9-b8f0-56e2cb94dfe9', text='解释一下上述代码中核心部分： 创建 AbortController：AbortController 用于在需要时中止请求。signal 是 AbortController 的一个属性，它将传递给 fetchEventSource 选项，以便在调用 controller.abort() 时中止请求。 调用 fetchEventSource： URL: 'http://localhost:8080/chat/completion' 方法: POST signal: 使用上面创建的 signal，用于控制请求的中止。 headers: 设置请求头，这里指定了 'Content-Type': 'application/json'。 body: 请求体，是一个 JSON 字符串，由 requestBody 对象转换而来。 事件处理： onmessage: 每次接收到服务器发送的事件时触发。事件对象 msg 包含事件类型 event 和数据 data。 如果 msg.event 是空字符串（表示默认的消息事件），则解析 msg.data（假设是 JSON 字符串），然后从解析后的对象中取出 v 属性，将其追加到 responseText 变量中。然后更新 chatList 中最后一条消息的内容为 responseText，并调用 scrollToBottom 函数（将聊天界面滚动到底部）。 如果 msg.event 是 'close'，则表示服务器通知关闭连接，此时调用 controller.abort() 中止请求。 onerror: 当发生错误时触发。这里直接抛出错误，因为根据 fetchEventSource 的文档，在 onerror 中抛出错误会停止重试并终止连接。如果不抛出，库会尝试重连。', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_inline, fileSize=11942}, score=null}]
