', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_block, lang=, fileSize=11942}, score=null}, Document{id='5bbaea7e-36ca-4037-a22f-1b689836cf0e', text='回到 ChatPage.vue 聊天对话页中，为 <ChatInputBox> 组件添加 v-model 指令，双向绑定到 message 变量上，默认值优先获取首页路由跳转，拿到的 firstMessage 字段, 若为空，则使用空字符串，并在 sendMessage() 发送消息事件方法中，构建请求 SSE 接口所需的请求体，代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=21, category=code_inline, title=构建请求体, fileSize=11942}, score=null}, Document{id='552bd8bc-2529-4d2f-b912-fb55898ba44a', text='          <!-- 提问输入框 -->
          <ChatInputBox
          v-model="message"
          containerClass="sticky max-w-3xl mx-auto bg-white bottom-8 left-0 w-full"
          @sendMessage="sendMessage"
          />
          
          // 省略...
          
          
<script setup>
// 省略...
import { useRoute } from 'vue-router'

// 省略...

const route = useRoute()

// 输入的消息
const message = ref(history.state?.firstMessage || '')

// 对话 ID
const chatId = ref(route.params.chatId || null)

// 发送消息
const sendMessage = async (payload) => {
  // 校验发送的消息不能为空
  if (!message.value.trim()) return

  console.log('选中的模型:', payload.selectedModel)
  console.log('是否联网:', payload.isNetworkSearch)

  // 将用户发送的消息添加到 chatList 聊天列表中
  const userMessage = message.value.trim()
  chatList.value.push({ role: 'user', content: userMessage })

  // 点击发送按钮后，清空输入框
  message.value = ''

  try {
    // 构建请求体
    const requestBody = {
      message: userMessage,
      chatId: chatId.value,
      modelName: payload.selectedModel?.name,
      networkSearch: payload.isNetworkSearch
    }

    // 打印请求体日志
    console.log(requestBody)

  } catch (error) {
    console.error('发送消息错误: ', error)
    // 提示用户 “请求出错”
    chatList.value[chatList.value.length - 1].content = '抱歉，请求出错了，请稍后重试。'
    // 滚动到底部
    scrollToBottom()
  }
}

// 省略...
</script>
