2025-11-07 18:16:42.236 [event-handler-1] INFO  com.quanxiaoha.ai.robot.event.listener.AiCustomerServiceMdUploadedListener - ## documents: [Document{id='36b05151-cddb-4f25-8fbf-a549d0a5ff07', text='本小节中，我们继续调试与开发前端项目，实现当用户在 “聊天输入框” 填入消息后，点击发送按钮，能够请求后端 /chat/completion  SSE 接口, 获取响应数据，并流式渲染 AI 大模型回复的消息。', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求}, score=null}, Document{id='e8d185f8-18c0-4d3c-a382-9392c153c0f3', text='在这之前，ChatInputBox.vue 聊天输入框还有点问题，需要先解决一下，那就是 —— 在聊天对话页中，如下图，当选择 AI 模型选择时，弹出的菜单出现在了下方，导致一部分菜单看不见了，交互上很不友好。我们希望当下方空间不足时，能够在上方弹出。为了实现这个功能，编辑 ChatInputBox.vue 组件，为下拉菜单添加代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=下拉框展示问题}, score=null}, Document{id='82115230-781e-4841-8eac-ad1cd5d183de', text='       <div class="flex gap-2 relative" ref="leftContainerRef">
       			// 省略...
                
                <!-- 下拉框菜单 -->
                <div v-if="isModelDropdownOpen" 
                ref="dropdownRef"
                :class="['absolute', 'left-0', 'w-48', 'bg-white', 'rounded-lg', 'shadow-lg', 'border', 'border-gray-200', 'z-10', 'overflow-hidden', dropdownPosition]"
                >
                    // 省略...
                </div>
                
                // 省略...
       </div>
                
<script setup>
import { ref, onMounted, onUnmounted, computed, nextTick } from 'vue'
// 省略...

// 下拉菜单父容器引用
const leftContainerRef = ref(null);

// 下拉菜单引用
const dropdownRef = ref(null)
// 下拉菜单位置
const dropdownPosition = ref('top-8') // 默认下方

// 下拉菜单显示/隐藏
const toggleModelDropdown = (event) => {
  isModelDropdownOpen.value = !isModelDropdownOpen.value

  // 如果下拉菜单显示，则计算位置
  if (isModelDropdownOpen.value) {
    nextTick(() => {
      if (leftContainerRef.value && dropdownRef.value) {
        // 返回元素相对于视图窗口的位置和尺寸信息
        const buttonRect = leftContainerRef.value.getBoundingClientRect();
        // 下拉菜单的实际高度
        const dropdownHeight = dropdownRef.value.offsetHeight;
        
        // 检查下方空间是否足够
        // 可用空间 = window.innerHeight - buttonRect.bottom
        // 所需空间 = dropdownHeight
        // 如果可用空间 < 所需空间，说明下方空间不足
        if (window.innerHeight - buttonRect.bottom < dropdownHeight) {
          // 下方空间不足，显示在上方
          dropdownPosition.value = 'bottom-10';
        } else {
          // 下方空间足够，显示在下方
          dropdownPosition.value = 'top-8';
        }
      }
    })
  }
}

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_block, lang=}, score=null}, Document{id='867461b5-1fe2-4b68-9c34-8743d094fe1c', text='解释一下新添加的代码： 新建 leftContainerRef 变量，引用下拉菜单的父级 <div> 容器； 新建 dropdownRef 变量，引用下拉菜单本身，用于获取其尺寸； 新建 dropdownPosition 响应式变量，用于控制下拉菜单显示位置，默认为 'top-8'（在触发元素下方）； 编辑 toggleModelDropdown 下拉菜单显示/隐藏方法，追加如果下拉菜单显示，则计算位置的处理逻辑： 使用 nextTick() 确保 DOM 已经更新，可以正确获取元素尺寸； 开始计算下拉框的显示位置，动态设置下拉菜单是显示在上方，还是下方；保存代码后，测试一下，这次在 “聊天对话页” 中，点击选择模型，下拉菜单就能动态显示在上方了：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, category=code_inline, mdStorageId=22}, score=null}, Document{id='0dd2fa2e-2624-49ca-ad66-6e8a4f925363', text='书归正文，回到本小节的主题。在 《4.7节》中，我们使用的是原生的 EventSource 来调用 SSE 接口，实现流式对话效果，但是，它有诸多局限性： 只支持 GET 请求； 无法自定义请求头； 不支持请求体； 有限的错误处理能力；', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=EventSource 的痛点}, score=null}, Document{id='b8c22b8f-452c-4943-adb4-0d7270e0ecb3', text='@microsoft/fetch-event-source 是微软开发的一个 JavaScript 库，提供了基于 Fetch API 的 Server-Sent Events (SSE) 客户端实现。它是对标准 EventSource API 的增强版本，提供了更多的灵活性和控制能力，很好的解决了原生 EventSource  的痛点。在 VSCode 中打开命令行，执行如下命令，安装 fetch-event-source 库：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=整合 fetch-event-source}, score=null}, Document{id='a6377017-3764-43be-9b2b-5cc6c30c0b89', text='npm install --save @microsoft/fetch-event-source
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_block, lang=}, score=null}, Document{id='02003591-7c59-431a-839f-7179c7015a41', text='回到 ChatPage.vue 聊天对话页中，为 <ChatInputBox> 组件添加 v-model 指令，双向绑定到 message 变量上，默认值优先获取首页路由跳转，拿到的 firstMessage 字段, 若为空，则使用空字符串，并在 sendMessage() 发送消息事件方法中，构建请求 SSE 接口所需的请求体，代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=构建请求体}, score=null}, Document{id='c867aed6-23f0-4886-9265-d74ae45ab8b9', text='          <!-- 提问输入框 -->
          <ChatInputBox
          v-model="message"
          containerClass="sticky max-w-3xl mx-auto bg-white bottom-8 left-0 w-full"
          @sendMessage="sendMessage"
          />
          
          // 省略...
          
          
<script setup>
// 省略...
import { useRoute } from 'vue-router'

// 省略...

const route = useRoute()

// 输入的消息
const message = ref(history.state?.firstMessage || '')

// 对话 ID
const chatId = ref(route.params.chatId || null)

// 发送消息
const sendMessage = async (payload) => {
  // 校验发送的消息不能为空
  if (!message.value.trim()) return

  console.log('选中的模型:', payload.selectedModel)
  console.log('是否联网:', payload.isNetworkSearch)

  // 将用户发送的消息添加到 chatList 聊天列表中
  const userMessage = message.value.trim()
  chatList.value.push({ role: 'user', content: userMessage })

  // 点击发送按钮后，清空输入框
  message.value = ''

  try {
    // 构建请求体
    const requestBody = {
      message: userMessage,
      chatId: chatId.value,
      modelName: payload.selectedModel?.name,
      networkSearch: payload.isNetworkSearch
    }

    // 打印请求体日志
    console.log(requestBody)

  } catch (error) {
    console.error('发送消息错误: ', error)
    // 提示用户 “请求出错”
    chatList.value[chatList.value.length - 1].content = '抱歉，请求出错了，请稍后重试。'
    // 滚动到底部
    scrollToBottom()
  }
}

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_block, lang=}, score=null}, Document{id='c29acd7b-e422-479e-9b3d-3929b28b96ea', text='保存代码，准备来测试一下。在 “聊天对话页” 中，输入一条信息，如 “你好”，点击发送按钮，观察前端控制台日志，确保打印的 requestBody 请求体参数正常：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, category=code_inline, mdStorageId=22}, score=null}, Document{id='3871cb63-1259-4d9a-85f9-ed9a5fe93eff', text='另外，针对首页输入的消息，点击发送按钮后，跳转到 “聊天对话页” ，也要适配一下：编辑  ChatPage.vue 聊天对话页，添加代码如下，在 onMounted() 生命周期方法中，判断跳转路由时，初始消息 firstMessage 是否为空，若不为空，主动调用 sendMessage() 方法，并将选择的模型、是否联网参数传递过去，代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=首页发送的消息}, score=null}, Document{id='6edc7b9a-71a5-4942-a9b5-ee27407f3518', text='<script setup>

// 省略...

// 导入Pinia store
import { useChatStore } from '@/stores/chatStore'

// 获取 chat store
const chatStore = useChatStore()

// 省略...

onMounted(() => {
  const firstMessage = history.state?.firstMessage
  // 检查跳转路由时，是否有初始消息
  if (firstMessage) {
    message.value = firstMessage
    // 发送消息
    sendMessage({
      selectedModel: chatStore.selectedModel,
      isNetworkSearch: chatStore.isNetworkSearchSelected
    })
  }
})

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_block, lang=}, score=null}, Document{id='332e546b-1eb0-4624-ba38-beaf40cd00a7', text='请求体构建完毕后，接下来，准备使用 fetch-event-source 库调用后端 SSE 接口，实现流式对话功能，最终效果如下：编辑 ChatPage.vue 聊天对话页，继续补充 sendMessage() 发送消息事件方法中的处理逻辑，代码如下：', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_inline, title=调用 SSE 接口}, score=null}, Document{id='8d4cf964-3243-4299-979c-16477d99f468', text='<script setup>
// 省略..
import { fetchEventSource } from '@microsoft/fetch-event-source'

// 省略...

// 发送消息
const sendMessage = async (payload) => {
  // 省略...

  // 点击发送按钮后，清空输入框
  message.value = ''

  // 添加一个占位的回复消息
  chatList.value.push({ role: 'assistant', content: ''})

  try {
    // 构建请求体
    const requestBody = {
      message: userMessage,
      chatId: chatId.value,
      modelName: payload.selectedModel?.name,
      networkSearch: payload.isNetworkSearch
    }

    // 响应的回答
    let responseText = ''
    // 获取最后一条消息
    const lastMessage = chatList.value[chatList.value.length - 1]

    const controller = new AbortController()
    const signal = controller.signal

	// 调用 SSE 流式对话接口
    fetchEventSource('http://localhost:8080/chat/completion', {
      method: 'POST',
      signal: signal,
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(requestBody),
      onmessage(msg) {
        if (msg.event === '') {
          // 解析 JSON
          let parseJson = JSON.parse(msg.data)
          // 持续追加流式回答
          responseText += parseJson.v

          // 更新最后一条消息
          chatList.value[chatList.value.length - 1].content = responseText
          // 滚动到底部
          scrollToBottom()
        }
        else if (msg.event === 'close') {
          console.log('-- sse close')
          controller.abort();
        }
      },
      onerror(err) {
        throw err;    // 必须 throw 才能停止 
      }
    })


  } catch (error) {
    // 省略...
  }

}

// 省略...
</script>
', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, mdStorageId=22, category=code_block, lang=}, score=null}, Document{id='3705e3e5-f3f1-4d6f-9426-08137e93ab03', text='解释一下上述代码中核心部分： 创建 AbortController：AbortController 用于在需要时中止请求。signal 是 AbortController 的一个属性，它将传递给 fetchEventSource 选项，以便在调用 controller.abort() 时中止请求。 调用 fetchEventSource： URL: 'http://localhost:8080/chat/completion' 方法: POST signal: 使用上面创建的 signal，用于控制请求的中止。 headers: 设置请求头，这里指定了 'Content-Type': 'application/json'。 body: 请求体，是一个 JSON 字符串，由 requestBody 对象转换而来。 事件处理： onmessage: 每次接收到服务器发送的事件时触发。事件对象 msg 包含事件类型 event 和数据 data。 如果 msg.event 是空字符串（表示默认的消息事件），则解析 msg.data（假设是 JSON 字符串），然后从解析后的对象中取出 v 属性，将其追加到 responseText 变量中。然后更新 chatList 中最后一条消息的内容为 responseText，并调用 scrollToBottom 函数（将聊天界面滚动到底部）。 如果 msg.event 是 'close'，则表示服务器通知关闭连接，此时调用 controller.abort() 中止请求。 onerror: 当发生错误时触发。这里直接抛出错误，因为根据 fetchEventSource 的文档，在 onerror 中抛出错误会停止重试并终止连接。如果不抛出，库会尝试重连。', media='null', metadata={originalFileName=整合微软 fetch-event-source 库：发送 Post 方式的 SSE 请求.md, category=code_inline, mdStorageId=22}, score=null}]
